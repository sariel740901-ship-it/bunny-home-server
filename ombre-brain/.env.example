# 复制这个文件为 .env，填好下面两个必填项即可启动:
#   cp .env.example .env

# ══ 必填 ══════════════════════════════════════════════

# 脱水/打标用的 LLM API Key（必填）
# 推荐免费方案: Google AI Studio → https://aistudio.google.com/apikey
OMBRE_COMPRESS_API_KEY=

# Dashboard 登录密码（必填，自己设一个，claude.ai 连接时 OAuth 授权也用它）
OMBRE_DASHBOARD_PASSWORD=

# ══ 可选（留空则用默认 / 之后在 Dashboard 里随时改）══════

# 脱水模型（推荐 gemini-2.0-flash + Google 的 OpenAI 兼容端点）
OMBRE_COMPRESS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OMBRE_COMPRESS_MODEL=gemini-2.0-flash

# 向量化模型（可留空，之后在 Dashboard 填；或用 --profile local 走本地 Ollama）
OMBRE_EMBED_API_KEY=
OMBRE_EMBED_BASE_URL=
OMBRE_EMBED_MODEL=

# 对外端口（默认 18001）
OMBRE_HOST_PORT=18001
