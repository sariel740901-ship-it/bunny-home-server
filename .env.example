# 复制此文件为 .env 并填入真实值
PORT=3000

# Supabase — 从项目设置中获取
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# 主对话模型 API（Anthropic 或中转服务）
ANTHROPIC_API_KEY=sk-xxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 辅助压缩模型（DeepSeek，成本更低）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# Ombre Brain 记忆桥（可选 — 配置后小克回复前会先检索记忆库）
# OMBRE_URL 是记忆库的公网地址(Cloudflare 隧道)，OMBRE_PASSWORD 是 Dashboard 密码
OMBRE_URL=https://brain.example.top
OMBRE_PASSWORD=
